{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "./dist-test",
    "rootDir": "./src",
    "declaration": false,
    "sourceMap": false,
    "types": ["node"]
  },
  "include": [
    "src/tests/premiumFeatures.test.ts",
    "src/tests/runTests.ts",
    "src/utils/premium/*.ts",
    "src/utils/taxCalculator.ts",
    "src/data/cities/**/*.ts",
    "src/types/**/*.ts"
  ],
  "exclude": [
    "src/utils/premium/pdfGenerator.ts",
    "node_modules"
  ]
}
